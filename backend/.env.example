# ── Database ──────────────────────────────────────────────────
# SQLite (local dev, default):
DATABASE_URL=sqlite:///./clario.db
# Postgres (production):
# DATABASE_URL=postgresql://clario:clario_secret@localhost:5432/clario_db

# ── Redis (Celery broker) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Groq AI (free tier) ───────────────────────────────────────
GROQ_API_KEY=your_groq_key_here

# ── Cloudflare R2 Storage (optional for local dev) ───────────
# Leave blank to use local disk storage during development
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clario-clips
R2_PUBLIC_URL=

# ── App Settings ─────────────────────────────────────────────
BASE_URL=http://localhost:8000
MEDIA_DIR=media
TEMP_DIR=temp

# ── Whisper Settings ─────────────────────────────────────────
# RTX 3050 → cuda + float16 is optimal
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# ── Segmentation ─────────────────────────────────────────────
SEGMENT_DURATION=60
MAX_SEGMENTS=20
